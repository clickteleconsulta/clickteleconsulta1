VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SITE_URL=http://localhost:3000

# JaaS (8x8 Jitsi as a Service) — Telemedicina
# Obter em: https://jaas.8x8.vc → My Account → Apps
VITE_JAAS_APP_ID=vpaas-magic-cookie-xxxx

# Secrets da Edge Function jaas-token (configurar no Supabase Dashboard,
# Settings → Edge Functions → Secrets — NUNCA colocar no .env do frontend):
#   JAAS_APP_ID      = mesmo valor de VITE_JAAS_APP_ID
#   JAAS_KEY_ID      = ID da chave RSA gerada no JaaS Dashboard
#   JAAS_PRIVATE_KEY = chave privada RSA em PEM (multi-linha com \n)

# WhatsApp Configuration (Disabled by default)
# REACT_APP_WHATSAPP_ENABLED=false
# REACT_APP_WHATSAPP_API_URL=
# REACT_APP_WHATSAPP_API_KEY=